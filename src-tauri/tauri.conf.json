{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Теплопроект",
  "version": "0.1.0",
  "identifier": "ru.teplo-project.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Теплопроект",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "language": ["ru-RU", "en-US"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/konstantin969696/teplo-project/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "RWSwQwu3PBaEkLQgI63zeZqheETYznfmjKG8zC0FytpifGcgTYFXhmBo"
    }
  }
}
